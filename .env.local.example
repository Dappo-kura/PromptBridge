# 翻訳プロバイダの選択: auto | deepl | google | mock
# auto の場合: DeepL(キーがあれば) -> Google無料エンドポイント -> 辞書ベース簡易翻訳 の順にフォールバック
TRANSLATE_PROVIDER=auto

# DeepL API Free のキー (任意)。設定すると DeepL を優先的に使用します。
# https://www.deepl.com/pro-api で取得できます。
DEEPL_API_KEY=

# LLMによる高精度タグ抽出 (Gemini)。設定すると辞書照合の代わりにLLMで意味抽出します。
# キーの取得: https://aistudio.google.com/apikey (Googleアカウントで無料発行、無料枠あり)
# 未設定の場合は従来の辞書照合で動作します。
GEMINI_API_KEY=
# 使用モデル (省略時: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
